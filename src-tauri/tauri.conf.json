{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage/dev/tauri/tauri.conf.schema.json",
  "productName": "Pixelle-Video",
  "version": "0.1.0",
  "identifier": "com.pixelle.video",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "npx vite --port 1420",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pixelle-Video",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../api/": "api/",
      "../pixelle_video/": "pixelle_video/",
      "../config.yaml": "config.yaml",
      "../data/": "data/",
      "binaries/python/": "python/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["**"],
        "deny": []
      }
    },
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-backend",
          "cmd": "python",
          "args": true
        },
        {
          "name": "python3-backend",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "bundled-python",
          "cmd": "python.exe",
          "args": true
        }
      ]
    }
  }
}
