{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage/dev/tauri/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capability set for Pixelle-Video",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn"
  ]
}
